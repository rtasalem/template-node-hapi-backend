{
  "name": "template-node-hapi-backend",
  "version": "0.0.0",
  "description": "Template for Node.js backend microservice utilising the Hapi.js plugin ecosystem",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "NODE_ENV=production node --use-strict .",
    "start:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "dev": "NODE_ENV=development npm run start:watch",
    "lint": "npx eslint . --ext .js",
    "lint:fix": "npx eslint . --ext .js --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtasalem/template-node-hapi-backend.git"
  },
  "author": "Rana Salem (github.com/rtasalem)",
  "license": "MIT",
  "dependencies": {
    "@hapi/hapi": "21.4.8",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "joi": "18.1.2"
  },
  "devDependencies": {
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "vitest": "4.1.4"
  }
}
